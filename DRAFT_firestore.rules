rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- 2. Entity Validations ---

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() <= 256
          && data.monthlyLimit is number && data.monthlyLimit >= 0
          && data.createdAt is string // In the app code it uses ISO string, ideally it should be server timestamp
          && data.keys().hasAll(['monthlyLimit', 'email', 'createdAt'])
          && data.keys().size() == 3;
    }

    function isValidTransaction(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() <= 256
          && data.vendor is string && data.vendor.size() > 0 && data.vendor.size() <= 256
          && data.amount is number && data.amount >= 0
          && data.category is string && data.category.size() > 0 && data.category.size() <= 100
          && data.date is string // ISO string
          && (data.get('subscriptionId', null) == null || data.subscriptionId is string)
          && data.keys().hasAll(['description', 'vendor', 'amount', 'category', 'date', 'subscriptionId'])
          && data.keys().size() == 6;
    }

    function isValidSubscription(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() <= 256
          && data.vendor is string && data.vendor.size() > 0 && data.vendor.size() <= 256
          && data.amount is number && data.amount >= 0
          && data.category is string && data.category.size() > 0 && data.category.size() <= 100
          && data.dayOfMonth is int && data.dayOfMonth >= 1 && data.dayOfMonth <= 31
          && data.active is bool
          && data.keys().hasAll(['description', 'vendor', 'amount', 'category', 'dayOfMonth', 'active'])
          && data.keys().size() == 6;
    }

    // --- 3. Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
                   && incoming().diff(existing()).affectedKeys().hasOnly(['monthlyLimit', 'email']);

      match /transactions/{transactionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidTransaction(incoming())
                     && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'vendor', 'amount', 'category', 'date', 'subscriptionId']);
        allow delete: if isOwner(userId);
      }

      match /subscriptions/{subscriptionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(subscriptionId) && isValidSubscription(incoming());
        allow update: if isOwner(userId) && isValidSubscription(incoming())
                     && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'vendor', 'amount', 'category', 'dayOfMonth', 'active']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
